# ── Auth.js ────────────────────────────────────────────────────────────────
# Generate with: bunx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=

# GitHub OAuth App credentials (Settings → Developer settings → OAuth Apps).
# Authorization callback URL must be:
#   http://localhost:3000/api/auth/callback/github   (local dev)
#   https://edit.gold-specht.de/api/auth/callback/github   (production)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Comma-separated GitHub logins allowed to sign in (everyone else is rejected,
# even though they'd still need write access to the repo to change anything).
ALLOWED_GITHUB_LOGINS=

# ── Target Hugo repository ───────────────────────────────────────────────────
# The private repo whose gallery this editor manages.
GITHUB_REPO_OWNER=SpechtLabs
GITHUB_REPO_NAME=GoldSpecht
GITHUB_REPO_BRANCH=main

# Path (within the repo) of the Hugo data file holding the gallery array,
# and where the gallery lives inside that YAML document.
GALLERY_DATA_PATH=data/de/portfolio.yml

# Where image files are stored in the repo, and how they're referenced from the
# YAML. IMAGE_DIR is the on-disk folder; IMAGE_PUBLIC_PREFIX is the URL prefix
# Hugo serves them under (static/images -> /images).
IMAGE_DIR=static/images
IMAGE_PUBLIC_PREFIX=/images
